// Общий модуль "РаботаСПользователями"
// Содержит процедуры для управления пользователями системы.

// Выполняет синхронизацию текущего пользователя информационной базы
// со справочником "Пользователи". Если запись для данного пользователя ИБ
// отсутствует, она автоматически создаётся.
// Может вызываться, например, при первом входе пользователя в систему
// или при необходимости актуализировать данные в справочнике.
#Область ПрограммныйИнтерфейс
Процедура СинхронизироватьПользователя() Экспорт
    // Получаем текущего пользователя ИБ
    ТекущийПользовательИБ = ПользователиИнформационнойБазы.ТекущийПользователь();   
	
	// Если пользователь ИБ не определён (фоновое задание, внешнее соединение),
    // выходим — синхронизация невозможна.
    Если ТекущийПользовательИБ = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    // Проверяем, существует ли элемент справочника с таким GUID в коде
    GUIDСтрока = Строка(ТекущийПользовательИБ.УникальныйИдентификатор);
	
	  // Ищем элемент справочника "Пользователи" с таким же кодом.
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |    Пользователи.Ссылка
    |ИЗ
    |    Справочник.Пользователи КАК Пользователи
    |ГДЕ
    |    Пользователи.Код = &Код";
    Запрос.УстановитьПараметр("Код", GUIDСтрока);
    
    Результат = Запрос.Выполнить();
	
	// Если результат запроса пуст — пользователь ещё не существует в справочнике.
    Если Результат.Пустой() Тогда
        // Создаём новый элемент справочника
        НовыйЭлемент = Справочники.Пользователи.СоздатьЭлемент();
        НовыйЭлемент.Код = GUIDСтрока;
        НовыйЭлемент.Наименование = ТекущийПользовательИБ.Имя;
        НовыйЭлемент.Записать();
    КонецЕсли;
КонецПроцедуры
#КонецОбласти
