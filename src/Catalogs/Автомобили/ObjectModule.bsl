// Модуль объекта справочника "Автомобили".
// Содержит бизнес-логику, выполняемую перед записью элемента.

// Обработчик события "ПередЗаписью".
// Проверяет корректность заполнения владельца автомобиля:
//   - Владелец должен быть указан (не пустая ссылка).
//   - Владелец должен быть контрагентом с типом "Покупатель" (физическое лицо).
// При нарушении условий выводится сообщение, и запись блокируется (Отказ = Истина).
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    
    Если Владелец.Пустая() Тогда
        Сообщить("Не указан владелец (клиент).");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Получаем объект контрагента-владельца
    КонтрагентОбъект = Владелец.ПолучитьОбъект();
    Если КонтрагентОбъект = Неопределено Тогда
        Сообщить("Не удалось определить тип контрагента.");
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Проверяем тип контрагента : автомобиль можно привязать только к покупателю (физлицу).
    Если КонтрагентОбъект.ТипКонтрагента <> Перечисления.ТипыКонтрагентов.Покупатель Тогда
        Сообщить("Автомобиль можно зарегистрировать только для клиента с типом 'Покупатель'.");
        Отказ = Истина;
    КонецЕсли;
КонецПроцедуры