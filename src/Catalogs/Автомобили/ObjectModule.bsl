// Модуль объекта справочника "Автомобили".
// Содержит бизнес-логику, выполняемую перед записью элемента.

// Обработчик события "ПередЗаписью".
// Проверяет корректность заполнения владельца автомобиля:
//   - Владелец должен быть указан (не пустая ссылка).
//   - Владелец должен быть контрагентом с типом "Покупатель" (физическое лицо).
// При нарушении условий выводится сообщение, и запись блокируется (Отказ = Истина).
#Область ОбработчикиСобытий
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
    // При загрузке данных из внешнего источника валидацию пропускаем
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;

	Если Владелец.Пустая() Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не указан владелец (клиент).";
		Сообщение.Поле = "Владелец";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	КонтрагентОбъект = Владелец.ПолучитьОбъект();
	Если КонтрагентОбъект = Неопределено Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Не удалось определить тип контрагента.";
		Сообщение.Сообщить();
		Отказ = Истина;
		Возврат;
	КонецЕсли;

	Если КонтрагентОбъект.ТипКонтрагента <> Перечисления.ТипыКонтрагентов.Покупатель Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Автомобиль можно зарегистрировать только для клиента с типом 'Покупатель'.";
		Сообщение.Поле = "Владелец";
		Сообщение.Сообщить();
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры
#КонецОбласти