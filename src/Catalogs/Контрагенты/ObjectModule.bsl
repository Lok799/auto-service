// Модуль объекта справочника "Контрагенты".
// Содержит бизнес-логику, выполняемую при записи элемента.

// Обработчик события "ПередЗаписью".
// Проверяет соответствие типа контрагента его родительской группе.
// Если контрагент помещается в предопределённую группу "Покупатели" или "Поставщики",
// то его тип должен совпадать с типом группы. В противном случае запись блокируется.
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
    // Получаем родительскую группу элемента.
	Родитель = ЭтотОбъект.Родитель;
    
    // Если родитель не задан (пустая ссылка), проверка не требуется.
	Если Родитель = Справочники.Контрагенты.ПустаяСсылка() Тогда
		Возврат;
	КонецЕсли;
    
    // Проверяем, является ли родитель одной из предопределённых групп.
	Если Родитель = Справочники.Контрагенты.Покупатели Или Родитель = Справочники.Контрагенты.Поставщики Тогда
        
        // Определяем допустимый тип контрагента для данной группы.
		ДопустимыйТип = Неопределено;
		Если Родитель = Справочники.Контрагенты.Покупатели Тогда
			ДопустимыйТип = Перечисления.ТипыКонтрагентов.Покупатель;
		Иначе
			ДопустимыйТип = Перечисления.ТипыКонтрагентов.Поставщик;
		КонецЕсли;
        
        // Сравниваем фактический тип контрагента с допустимым.
		Если ЭтотОбъект.ТипКонтрагента <> ДопустимыйТип Тогда
			Сообщить("Ошибка: в группе """ + Родитель.Наименование + """ можно создавать элементы только с типом """
				+ Строка(ДопустимыйТип) + """.");
			Отказ = Истина; // Блокируем запись.
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры