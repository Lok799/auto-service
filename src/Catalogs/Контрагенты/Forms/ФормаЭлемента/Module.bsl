// Форма элемента справочника "Контрагенты".
// Динамически изменяет интерфейс в зависимости от типа контрагента:
// для покупателей (физических лиц) показываются поля, связанные с клиентом,
// для остальных (юридических лиц) – поля для договоров и наименования организации.

#Область ОбработчикиСобытийФормы

// Серверный обработчик создания нового элемента.
// Устанавливает тип контрагента по умолчанию, чтобы интерфейс сразу отобразился корректно.
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    // Для нового элемента назначаем тип "Покупатель" (наиболее частый сценарий).
    Объект.ТипКонтрагента = ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.Покупатель");
КонецПроцедуры

// Обработчик открытия формы (клиент).
// Выполняет первичную настройку интерфейса согласно текущему типу контрагента.
&НаКлиенте
Процедура ПриОткрытии(Отказ)
    УстановитьПодписьНаименования();
    УправлятьВидимостьюРеквизитов();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// Обработчик изменения реквизита "ТипКонтрагента".
// При смене типа обновляем заголовок поля "Наименование" и видимость реквизитов.
&НаКлиенте
Процедура ТипКонтрагентаПриИзменении(Элемент)
    // Защита от Неопределено (на случай, если значение сброшено).
    Если Объект.ТипКонтрагента = Неопределено Тогда
        Возврат;
    КонецЕсли;
    УстановитьПодписьНаименования();
    УправлятьВидимостьюРеквизитов();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Меняет заголовок поля "Наименование" в зависимости от типа контрагента.
// Для покупателя (физического лица) заголовок становится "ФИО",
// для всех остальных – "Наименование" (юридическое лицо).
&НаКлиенте
Процедура УстановитьПодписьНаименования()
    Если Объект.ТипКонтрагента = ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.Покупатель") Тогда
        Элементы.Наименование.Заголовок = "ФИО";
    Иначе
        Элементы.Наименование.Заголовок = "Наименование";
    КонецЕсли;
КонецПроцедуры

// Управляет видимостью дополнительных реквизитов формы в зависимости от типа контрагента.
// Для покупателя видны: "ДатаРожденияКлиента", "ПолКлиента", "Источник".
// Скрыты: "Договор".
// Для остальных типов – наоборот.
&НаКлиенте
Процедура УправлятьВидимостьюРеквизитов()
    Если Объект.ТипКонтрагента = ПредопределенноеЗначение("Перечисление.ТипыКонтрагентов.Покупатель") Тогда
        Элементы.ДатаРожденияКлиента.Видимость   = Истина;
        Элементы.ПолКлиента.Видимость            = Истина;
        Элементы.Договор.Видимость               = Ложь;
        Элементы.Источник.Видимость              = Истина;
    Иначе
        Элементы.ДатаРожденияКлиента.Видимость   = Ложь;
        Элементы.ПолКлиента.Видимость            = Ложь;
        Элементы.Договор.Видимость               = Истина;
        Элементы.Источник.Видимость              = Ложь;
    КонецЕсли;
КонецПроцедуры

#КонецОбласти