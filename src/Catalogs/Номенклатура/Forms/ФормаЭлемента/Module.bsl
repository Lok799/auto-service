// Форма элемента справочника "Номенклатура".
// Управляет видимостью реквизитов и подбором счёта бухгалтерского учёта
// в зависимости от выбранного типа номенклатуры (Товар, Услуга, Материал и т.д.).

// При открытии формы скрываем или показываем поле "ДлительностьУслуги".
// Для материальных типов (Материал, Товар, МатериалКлиента) длительность не нужна,
// для услуг и прочих — показываем.
&НаКлиенте
Процедура ПриОткрытии(Отказ)
    // Проверяем текущий тип номенклатуры и устанавливаем видимость.
    Если Объект.ТипНоменклатуры      = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Материал") 
        ИЛИ Объект.ТипНоменклатуры   = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Товар")
        ИЛИ Объект.ТипНоменклатуры   = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.МатериалКлиента") Тогда 
        Элементы.ДлительностьУслуги.Видимость = Ложь;
    Иначе
        Элементы.ДлительностьУслуги.Видимость = Истина;
    КонецЕсли;
КонецПроцедуры

// При изменении типа номенклатуры пользователем обновляем видимость поля "ДлительностьУслуги"
// и сразу подбираем соответствующий счёт бухгалтерского учёта через серверный вызов.
&НаКлиенте
Процедура ТипНоменклатурыПриИзменении(Элемент)
    // Дублируем логику видимости (аналогично ПриОткрытии).
    Если Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Материал") 
        ИЛИ Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Товар")
        ИЛИ Объект.ТипНоменклатуры   = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.МатериалКлиента") Тогда 
        Элементы.ДлительностьУслуги.Видимость = Ложь;
    Иначе
        Элементы.ДлительностьУслуги.Видимость = Истина;
    КонецЕсли; 
    // Автоматически определяем и подставляем счёт бухучёта для выбранного типа.
    Объект.СчетБухгалтерскогоУчета = ОпределитьСчетПоТипуНоменклатуры(Объект.ТипНоменклатуры);
КонецПроцедуры

// Обработчик начала выбора для поля "СчетБухгалтерскогоУчета".
// Формирует ограниченный список доступных счетов в зависимости от типа номенклатуры,
// чтобы пользователь не мог выбрать неподходящий счёт.
&НаКлиенте
Процедура СчетБухгалтерскогоУчетаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
    // Отключаем стандартную обработку, чтобы заменить её нашим списком.
    СтандартнаяОбработка = Ложь;
    
    СписокДоступныхЗначений = Новый СписокЗначений;    
    // Для товаров доступен только счёт "Товары" (счёт 41).
    Если Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Товар") Тогда
        СписокДоступныхЗначений.Добавить(ПредопределенноеЗначение("ПланСчетов.Хозрасчетный.Товары"));
    ИначеЕсли  
        // Для услуг доступны счета 44 "Расходы на продажу" и 91 "Прочие доходы и расходы".
        Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга") Тогда
        СписокДоступныхЗначений.Добавить(ПредопределенноеЗначение("ПланСчетов.Хозрасчетный.РасходыНаПродажу"));
        СписокДоступныхЗначений.Добавить(ПредопределенноеЗначение("ПланСчетов.Хозрасчетный.ПрочиеДоходыИРасходы"));
    ИначеЕсли
        // Для материалов доступен счёт "Материалы" (счёт 10).
        Объект.ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Материал") Тогда
        СписокДоступныхЗначений.Добавить(ПредопределенноеЗначение("ПланСчетов.Хозрасчетный.Материалы"));
    Иначе    
        // Для остальных типов (например, МатериалКлиента) доступен пустой счёт,
        // что позволяет не указывать счёт бухучёта.
        СписокДоступныхЗначений.Добавить(ПредопределенноеЗначение("ПланСчетов.Хозрасчетный.ПустаяСсылка"));
    КонецЕсли;
    
    // Возвращаем подготовленный список в качестве данных выбора.
    ДанныеВыбора = СписокДоступныхЗначений;
КонецПроцедуры

// Серверная функция, возвращающая счёт бухучёта по типу номенклатуры.
// Параметры:
//   ТипНоменклатуры - ПеречислениеСсылка.ТипыНоменклатуры - тип номенклатуры.
// Возвращает:
//   ПланСчетовСсылка.Хозрасчетный - предопределённый счёт, соответствующий типу,
//   или Неопределено для неизвестных типов.
&НаСервере
Функция ОпределитьСчетПоТипуНоменклатуры(ТипНоменклатуры)
    Если ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Товар") Тогда
        Возврат ПланыСчетов.Хозрасчетный.НайтиПоКоду("41");
    ИначеЕсли 
        ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Услуга") Тогда
        Возврат ПланыСчетов.Хозрасчетный.НайтиПоКоду("44");
    ИначеЕсли
        ТипНоменклатуры = ПредопределенноеЗначение("Перечисление.ТипыНоменклатуры.Материал") Тогда
        Возврат ПланыСчетов.Хозрасчетный.НайтиПоКоду("10");
    Иначе
        Возврат Неопределено;
    КонецЕсли;
КонецФункции