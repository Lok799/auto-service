#Область ОбработчикиСобытий

// Обработчик события "ПередЗаписью".
// Проверяет соответствие типа номенклатуры её родительской группе.
// Если номенклатура помещается в предопределённую группу (Товары, Услуги, МатериалыСобственные, МатериалыКлиента),
// то её тип должен совпадать с типом группы. В противном случае запись блокируется.
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	Если ОбменДанными.Загрузка Тогда
		Возврат;
	КонецЕсли;
	
	// Получаем родителя (группу) напрямую из реквизита
	Родитель = Родитель;
	
	// Если родитель не определен, проверять не нужно
	Если Родитель = Справочники.Номенклатура.ПустаяСсылка() Тогда
		Возврат;
	КонецЕсли;
	
	// Проверяем, является ли родитель одной из предопределенных групп
	Если Родитель = Справочники.Номенклатура.Товары 
		Или Родитель = Справочники.Номенклатура.Услуги 
		Или Родитель = Справочники.Номенклатура.МатериалыСобственные 
		Или Родитель = Справочники.Номенклатура.МатериалыКлиента Тогда
		
		// Определяем допустимый тип для данной группы
		ДопустимыйТип = Неопределено;
		Если Родитель = Справочники.Номенклатура.Товары Тогда
			ДопустимыйТип = Перечисления.ТипыНоменклатуры.Товар;
		ИначеЕсли Родитель = Справочники.Номенклатура.Услуги Тогда
			ДопустимыйТип = Перечисления.ТипыНоменклатуры.Услуга;
		ИначеЕсли Родитель = Справочники.Номенклатура.МатериалыСобственные Тогда
			ДопустимыйТип = Перечисления.ТипыНоменклатуры.Материал;
		ИначеЕсли Родитель = Справочники.Номенклатура.МатериалыКлиента Тогда
			ДопустимыйТип = Перечисления.ТипыНоменклатуры.МатериалКлиента;
		КонецЕсли;
		
		// Сравниваем фактический тип с допустимым
		Если ТипНоменклатуры <> ДопустимыйТип Тогда
			// Явно получаем объект родителя для доступа к наименованию
			РодительОбъект = Родитель.ПолучитьОбъект();
			ИмяГруппы = ?(РодительОбъект <> Неопределено, РодительОбъект.Наименование, Строка(Родитель));
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = "Ошибка: в группе """ + ИмяГруппы + """ можно создавать элементы только с типом """
				+ Строка(ДопустимыйТип) + """.";
			Сообщение.Сообщить();
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти