// Модуль сеанса конфигурации
// Отвечает за инициализацию параметров сеанса.
// Основная задача – синхронизация текущего пользователя информационной базы
// со справочником "Пользователи" и заполнение параметра "ТекущийПользователь".

#Область ОбработчикиСобытий

Процедура УстановкаПараметровСеанса(ИменаПараметровСеанса) Экспорт
    // Если список имён параметров не передан, выходим.
    Если ИменаПараметровСеанса = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    // Массив для отслеживания уже обработанных параметров.
    // Позволяет избежать повторной инициализации одного и того же параметра.
    УстановленныеПараметры = Новый Массив;
    Для Каждого ИмяПараметра Из ИменаПараметровСеанса Цикл
        УстановитьЗначениеПараметраСеанса(ИмяПараметра, УстановленныеПараметры);
    КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Устанавливает значение конкретного параметра сеанса.
// Параметры:
//   ИмяПараметра           - Строка - имя параметра сеанса.
//   УстановленныеПараметры - Массив из Строка - коллекция уже обработанных имён (передаётся по ссылке).
Процедура УстановитьЗначениеПараметраСеанса(Знач ИмяПараметра, УстановленныеПараметры)
    
    // Если параметр уже был обработан в рамках текущего вызова, ничего не делаем.
    Если УстановленныеПараметры.Найти(ИмяПараметра) <> Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    // Логика инициализации параметра "ТекущийПользователь".
    // Связывает учётную запись пользователя ИБ с элементом справочника "Пользователи",
    // создавая запись при необходимости.
    Если ИмяПараметра = "ТекущийПользователь" Тогда 
        // Получаем объект текущего пользователя информационной базы.
        ПользовательИБ = ПользователиИнформационнойБазы.ТекущийПользователь();
        
        // Если пользователь ИБ не определён (фоновое задание, веб-сервис),
        // параметр не заполняется, чтобы не создавать ошибок в бизнес-логике.
        Если ПользовательИБ = Неопределено Тогда    
            Возврат;
        КонецЕсли;
        
        // Ищем запись в справочнике "Пользователи" по уникальному идентификатору.
        // Идентификатор пользователя ИБ используется как код элемента справочника.
        ИдентификаторСтрокой = Строка(ПользовательИБ.УникальныйИдентификатор);
        ТекущийПользователь = Справочники.Пользователи.НайтиПоКоду(ИдентификаторСтрокой);
        
        // Если запись не найдена, создаём новый элемент справочника.
        Если ТекущийПользователь.Пустая() Тогда 
            ПользовательОбъект = Справочники.Пользователи.СоздатьЭлемент();
            ПользовательОбъект.Код = ИдентификаторСтрокой;
            ПользовательОбъект.Наименование = ПользовательИБ.Имя;
            ПользовательОбъект.Записать();
            ТекущийПользователь = ПользовательОбъект.Ссылка;
        КонецЕсли;
        
        // Заполняем параметр сеанса.
        ПараметрыСеанса.ТекущийПользователь = ТекущийПользователь;
    КонецЕсли;
    
    // Помечаем параметр как обработанный.
    УстановленныеПараметры.Добавить(ИмяПараметра);
КонецПроцедуры

#КонецОбласти