// Форма документа "ПриходныйКассовыйОрдер".
// Обеспечивает:
//   - установку ответственного по умолчанию (текущий пользователь),
//   - динамическое управление типом плательщика (контрагент или сотрудник) в зависимости от вида операции,
//   - управление видимостью поля "Договор" (скрыто для возвратов от подотчетника и для покупателей),
//   - проверку, является ли контрагент покупателем, для скрытия договора.

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    // Заполнение ответственного текущим пользователем
    Если Не ЗначениеЗаполнено(Объект.Ответственный) Тогда
        Объект.Ответственный = ПараметрыСеанса.ТекущийПользователь;
    КонецЕсли;
    
    УправлятьВидимостьюЭлементовНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ) 
    УправлятьТипомПлательщикаНаКлиенте();
    УправлятьВидимостьюЭлементовНаСервере();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
    УправлятьТипомПлательщикаНаКлиенте();
    УправлятьВидимостьюЭлементовНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПлательщикПриИзменении(Элемент)
    УправлятьВидимостьюЭлементовНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Проверяет, является ли контрагент покупателем.
// Параметры:
//   СсылкаНаКонтрагента - СправочникСсылка.Контрагенты - (может быть пустой ссылкой).
// Возвращаемое значение:
//   Булево - Истина, если тип контрагента = Покупатель; Ложь в противном случае или если ссылка не заполнена.
&НаСервере
Функция КонтрагентПокупатель(СсылкаНаКонтрагента)  // убрали Экспорт
    Если Не ЗначениеЗаполнено(СсылкаНаКонтрагента) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |    Контрагенты.ТипКонтрагента = &ТипПокупатель КАК Покупатель
    |ИЗ
    |    Справочник.Контрагенты КАК Контрагенты
    |ГДЕ
    |    Контрагенты.Ссылка = &Ссылка";
    
    Запрос.УстановитьПараметр("Ссылка", СсылкаНаКонтрагента);
    Запрос.УстановитьПараметр("ТипПокупатель", Перечисления.ТипыКонтрагентов.Покупатель);
    
    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Покупатель;
    КонецЕсли;
    
    Возврат Ложь;
КонецФункции

// Управляет видимостью элемента "Договор" на сервере.
&НаСервере
Процедура УправлятьВидимостьюЭлементовНаСервере()
    Если Объект.ВидОперации = Перечисления.ВидыОперацийПоступленияДенег.ВозвратОтПодотчетника Тогда
        Элементы.Договор.Видимость = Ложь;
    Иначе
        Если ЗначениеЗаполнено(Объект.Плательщик) И 
            ТипЗнч(Объект.Плательщик) = Тип("СправочникСсылка.Контрагенты") Тогда
            ЯвляетсяПокупателем = КонтрагентПокупатель(Объект.Плательщик);
            Элементы.Договор.Видимость = Не ЯвляетсяПокупателем;
        Иначе
            Элементы.Договор.Видимость = Истина;
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УправлятьТипомПлательщикаНаКлиенте()
    Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПоступленияДенег.ВозвратОтПодотчетника") Тогда
        Элементы.Плательщик.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Сотрудники");
        Если Объект.Плательщик <> Неопределено И
            ТипЗнч(Объект.Плательщик) <> Тип("СправочникСсылка.Сотрудники") Тогда
            Объект.Плательщик = Неопределено;
        КонецЕсли;
    Иначе
        Элементы.Плательщик.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
        Если Объект.Плательщик <> Неопределено И
            ТипЗнч(Объект.Плательщик) <> Тип("СправочникСсылка.Контрагенты") Тогда
            Объект.Плательщик = Неопределено;
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

#КонецОбласти