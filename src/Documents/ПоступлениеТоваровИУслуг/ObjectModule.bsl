// Модуль объекта документа "ПоступлениеТоваровИУслуг".
// Содержит основную логику проведения документа: формирование движений
// по регистрам накопления "ТоварыНаСкладах", "УчетЗатрат" и бухгалтерскому
// регистру "Хозрасчетный" в зависимости от учётной политики.

// Главный обработчик проведения документа.
// Параметры:
//   Отказ - Булево - признак отказа от проведения (если Истина, проведение отменяется).
//   Режим - РежимПроведенияДокумента - режим проведения (оперативный или неоперативный).
#Область ОбработчикиСобытий
Процедура ОбработкаПроведения(Отказ, Режим)
	
	// 1. Определяем способ учёта запасов из регистра сведений "УчетнаяПолитика".
	// Получаем последнюю актуальную запись на дату документа.
	СтруктураУчетнаяПолитика = РегистрыСведений.УчетнаяПолитика.ПолучитьПоследнее(Дата);
	Если СтруктураУчетнаяПолитика.СпособУчетаЗапасов = Перечисления.СпособыСписанияЗапасов.FEFO Тогда
		ОтражатьСрокиГодности = Истина;
	Иначе
		ОтражатьСрокиГодности = Ложь;
	КонецЕсли;
	
	// 2. Включаем запись движений для используемых регистров.
	Движения.ТоварыНаСкладах.Записывать = Истина;
	Движения.УчетЗатрат.Записывать = Истина;
	Движения.Хозрасчетный.Записывать = Истина;
	
	// ========== 1. Обработка табличной части "Товары" ==========   
	Если Товары.Количество() <> 0 Тогда
		
		// Запрос к табличной части документа для группировки одноимённых товаров
		// (с одинаковым сроком годности и счётом бухучёта), чтобы свернуть их в одно движение.
		ЗапросТовары = Новый Запрос;
		ЗапросТовары.УстановитьПараметр("Ссылка", Ссылка);
		ЗапросТовары.Текст = 
		"ВЫБРАТЬ
		|    ПоступлениеТовары.Номенклатура КАК Номенклатура,
		|    СУММА(ПоступлениеТовары.Количество) КАК Количество,
		|    СУММА(ПоступлениеТовары.Сумма) КАК Сумма,
		|    ПоступлениеТовары.СрокГодности КАК СрокГодности,
		|    ПоступлениеТовары.Номенклатура.СчетБухгалтерскогоУчета КАК СчетБухгалтерскогоУчета
		|ИЗ
		|    Документ.ПоступлениеТоваровИУслуг.Товары КАК ПоступлениеТовары
		|ГДЕ
		|    ПоступлениеТовары.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|    ПоступлениеТовары.Номенклатура,
		|    ПоступлениеТовары.СрокГодности,
		|    ПоступлениеТовары.Номенклатура.СчетБухгалтерскогоУчета";
		
		ВыборкаТовары = ЗапросТовары.Выполнить().Выбрать();
		Пока ВыборкаТовары.Следующий() Цикл
			// Движение прихода на склад.
			Движение = Движения.ТоварыНаСкладах.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
			Движение.Период = Дата;
			Движение.Номенклатура = ВыборкаТовары.Номенклатура;
			Движение.Склад = Склад;
			Движение.Количество = ВыборкаТовары.Количество;
			Движение.Сумма = ВыборкаТовары.Сумма;
			// Если учётная политика FEFO, заполняем срок годности и формируем бухгалтерские проводки.
			Если ОтражатьСрокиГодности Тогда
				Движение.СрокГодности = ВыборкаТовары.СрокГодности; 
			КонецЕсли;
			
			// Бухгалтерская проводка: Дт СчетУчетаТовара Кт 60.01 (РасчетыСПоставщиками).
			Движение = Движения.Хозрасчетный.Добавить();
			Движение.СчетДт = ВыборкаТовары.СчетБухгалтерскогоУчета;
			Движение.СчетКт = ПланыСчетов.Хозрасчетный.РасчетыСПоставщиками;
			Движение.Период = Дата;
			Движение.Сумма = ВыборкаТовары.Сумма;
			Движение.Содержание = "Отражено поступление товарно-материальных ценностей от поставщика";
			// Заполняем аналитику: на дебет – номенклатура, на кредит – контрагент.
			Движение.СубконтоДт[ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура] = ВыборкаТовары.Номенклатура;
			Движение.СубконтоКт[ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Контрагенты] = Контрагент;
		КонецЦикла; 
	КонецЕсли;
	
	// ========== 2. Обработка табличной части "Услуги" ==========  
	Если Услуги.Количество() <> 0 Тогда
		
		// Запрос к табличной части услуг с группировкой по статье затрат.
		// Используются ИТОГИ для иерархического обхода.
		ЗапросУслуги = Новый Запрос;
		ЗапросУслуги.УстановитьПараметр("Ссылка", Ссылка);
		ЗапросУслуги.Текст = 
		"ВЫБРАТЬ
		|    ПоступлениеУслуги.СтатьяЗатрат КАК СтатьяЗатрат,
		|    СУММА(ПоступлениеУслуги.Сумма) КАК Сумма,
		|    ПоступлениеУслуги.Услуга.СчетБухгалтерскогоУчета КАК СчетБухгалтерскогоУчета
		|ИЗ
		|    Документ.ПоступлениеТоваровИУслуг.Услуги КАК ПоступлениеУслуги
		|ГДЕ
		|    ПоступлениеУслуги.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|    ПоступлениеУслуги.СтатьяЗатрат,
		|    ПоступлениеУслуги.Услуга.СчетБухгалтерскогоУчета
		|ИТОГИ
		|    СУММА(Сумма)
		|ПО
		|    СтатьяЗатрат";
		
		// Обход с группировками: сначала внешний цикл по статьям затрат, затем вложенный – по детальным записям.
		ВыборкаУслуги = ЗапросУслуги.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); 
		Пока ВыборкаУслуги.Следующий() Цикл
			// Движение в регистр "УчетЗатрат" – общая сумма по статье.
			Движение = Движения.УчетЗатрат.Добавить();
			ЗаполнитьЗначенияСвойств(Движение,ВыборкаУслуги);
			Движение.Период = Дата;
			Движение.СтатьяЗатрат = ВыборкаУслуги.СтатьяЗатрат;
			
			// Вложенный обход – детальные записи по услугам для формирования проводок.
			ВыборкаДетальныеЗаписи = ВыборкаУслуги.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				// Бухгалтерская проводка: Дт СчетУчетаУслуги Кт 60.01.
				Движение = Движения.Хозрасчетный.Добавить();
				Движение.СчетДт = ВыборкаДетальныеЗаписи.СчетБухгалтерскогоУчета;
				Движение.СчетКт = ПланыСчетов.Хозрасчетный.РасчетыСПоставщиками;
				Движение.Период = Дата;
				Движение.Сумма = ВыборкаДетальныеЗаписи.Сумма;
				Движение.Содержание = "Отражено поступление услуг от поставщика";
				// Заполняем субконто с помощью процедуры из общего модуля.
				БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(Движение.СчетДт, Движение.СубконтоДт, ВыборкаДетальныеЗаписи.СтатьяЗатрат);
				БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(Движение.СчетКт, Движение.СубконтоКт, Контрагент); 
			КонецЦикла;  
		КонецЦикла;        
	КонецЕсли;
	
КонецПроцедуры
#КонецОбласти