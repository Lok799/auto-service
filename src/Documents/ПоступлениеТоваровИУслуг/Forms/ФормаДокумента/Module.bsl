// Форма документа "ПоступлениеТоваровИУслуг".
// Управляет интерактивным заполнением, автоматическим расчётом сумм,
// подстановкой статей затрат и установкой ответственного по умолчанию.

// ============================================================
//  Серверные обработчики
// ============================================================

// При создании нового документа на сервере:
//   - Если ответственный не заполнен, подставляем текущего пользователя
//     из параметров сеанса (это ссылка на элемент справочника "Пользователи").
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка) 
    Если Не ЗначениеЗаполнено(Объект.Ответственный) Тогда
        Объект.Ответственный = ПараметрыСеанса.ТекущийПользователь;
    КонецЕсли;
КонецПроцедуры

// Серверная функция без контекста формы (быстрее, не передаёт данные формы).
// Возвращает статью затрат, назначенную для переданной номенклатуры (услуги).
// Используется для автозаполнения статьи затрат в строке табличной части "Услуги".
&НаСервереБезКонтекста
Функция ПолучитьСтатьюЗатратПоНоменклатуре(Услуга)
    Запрос = Новый Запрос;
    Запрос.УстановитьПараметр("Ссылка", Услуга);
    Запрос.Текст=
    "ВЫБРАТЬ
    |    Номенклатура.СтатьяЗатрат КАК СтатьяЗатрат
    |ИЗ
    |    Справочник.Номенклатура КАК Номенклатура
    |ГДЕ
    |    Номенклатура.Ссылка = &Ссылка";
    Выборка = Запрос.Выполнить().Выбрать();
    Выборка.Следующий();
    Возврат Выборка.СтатьяЗатрат;
КонецФункции

// ============================================================
//  Клиентские процедуры пересчёта итоговой суммы документа
// ============================================================

// Обновляет итоговую сумму документа как сумму колонок "Сумма"
// по обеим табличным частям (Товары и Услуги).
&НаКлиенте 
Процедура ПересчётСуммыДокумента()
    Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
КонецПроцедуры   

// ============================================================
//  Обработчики табличной части "Товары"
// ============================================================

// При изменении количества в строке товара:
//   - пересчитываем сумму в строке (Цена * Количество),
//   - обновляем итоговую сумму документа.
&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
    СтрокаТЧ = Элементы.Товары.ТекущиеДанные;
    Если СтрокаТЧ <> Неопределено Тогда
        РаботаСТабличнымиЧастямиКлиент.ПересчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТЧ);
        ПересчётСуммыДокумента();
    КонецЕсли;
КонецПроцедуры

// При изменении цены в строке товара – аналогично пересчитываем сумму.
&НаКлиенте
Процедура ТоварыЦенаПриИзменении(Элемент)
    СтрокаТЧ = Элементы.Товары.ТекущиеДанные;
    Если СтрокаТЧ <> Неопределено Тогда
        РаботаСТабличнымиЧастямиКлиент.ПересчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТЧ);
        ПересчётСуммыДокумента();
    КонецЕсли;
КонецПроцедуры

// При начале редактирования новой строки (копирование существующей):
//   - пересчитываем итог, так как появилась новая сумма.
&НаКлиенте
Процедура ТоварыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
    Если Копирование Тогда
        ПересчётСуммыДокумента();
    КонецЕсли;
КонецПроцедуры

// После удаления строки товара пересчитываем итог.
&НаКлиенте
Процедура ТоварыПослеУдаления(Элемент)
    ПересчётСуммыДокумента();
КонецПроцедуры

// ============================================================
//  Обработчики табличной части "Услуги"
// ============================================================

// Изменение количества в строке услуги: пересчёт строки и итога.
&НаКлиенте
Процедура УслугиКоличествоПриИзменении(Элемент)
    СтрокаТЧ = Элементы.Услуги.ТекущиеДанные;
    Если СтрокаТЧ <> Неопределено Тогда
        РаботаСТабличнымиЧастямиКлиент.ПересчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТЧ);
        ПересчётСуммыДокумента();
    КонецЕсли;
КонецПроцедуры

// Изменение цены в строке услуги: пересчёт строки и итога.
&НаКлиенте
Процедура УслугиЦенаПриИзменении(Элемент)
    СтрокаТЧ = Элементы.Услуги.ТекущиеДанные;
    Если СтрокаТЧ <> Неопределено Тогда
        РаботаСТабличнымиЧастямиКлиент.ПересчитатьСуммуВСтрокеТабличнойЧасти(СтрокаТЧ);
        ПересчётСуммыДокумента();
    КонецЕсли;
КонецПроцедуры

// При выборе услуги в строке:
//   - автоматически подтягиваем статью затрат из справочника "Номенклатура"
//     с помощью серверной функции.
&НаКлиенте
Процедура УслугиУслугаПриИзменении(Элемент)
    СтрокаТЧ = Элементы.Услуги.ТекущиеДанные;
    Если ЗначениеЗаполнено(СтрокаТЧ.Услуга) Тогда
        СтрокаТЧ.СтатьяЗатрат = ПолучитьСтатьюЗатратПоНоменклатуре(СтрокаТЧ.Услуга);
    КонецЕсли; 
КонецПроцедуры

// Начало редактирования новой строки (копирование).
&НаКлиенте
Процедура УслугиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
    Если Копирование Тогда
        ПересчётСуммыДокумента();
    КонецЕсли;
КонецПроцедуры

// После удаления строки услуги.
&НаКлиенте
Процедура УслугиПослеУдаления(Элемент)
    ПересчётСуммыДокумента();
КонецПроцедуры