// Модуль объекта документа "Реализация".
// Содержит:
//   1. Обработчик заполнения "на основании" документа "ЗаказНаряд" (сгенерирован конструктором).
//   2. Основную логику проведения с контролем остатков, партионным списанием
//      (FEFO – по сроку годности), формированием движений по нескольким регистрам
//      и бухгалтерскими проводками.

#Область ОбработчикиСобытий

// Данный фрагмент автоматически построен конструктором ввода на основании.
// Заполняет реквизиты и табличные части нового документа "Реализация"
// на основе данных выбранного документа-основания "ЗаказНаряд".
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
    //{{__КОНСТРУКТОР_ВВОД_НА_ОСНОВАНИИ
    // Данный фрагмент построен конструктором.
    // При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
    Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ЗаказНаряд") Тогда
        // Явно получаем объект-основание, чтобы избежать неявных загрузок из базы.
        ОбъектОснование = ДанныеЗаполнения.ПолучитьОбъект();
        Если ОбъектОснование = Неопределено Тогда
            Возврат;
        КонецЕсли;
        
        // Заполнение шапки из документа-основания.
        ДокументОснование = ДанныеЗаполнения;   // ссылка на основание
        
        НомерЗаказа = ОбъектОснование.Номер;
        ДатаЗаказа = Формат(ОбъектОснование.Дата, "ДЛФ=DD.MM.YYYY");
        Автомобиль = ОбъектОснование.Автомобиль;
        Контрагент = ОбъектОснование.Клиент;
        Комментарий = "Введен на основании: Заказ-наряд №" + НомерЗаказа + " от " + ДатаЗаказа;
        Сотрудник = ОбъектОснование.Сотрудник;
        СуммаДокумента = ОбъектОснование.СуммаДокумента;
        
        // Перенос материалов заказчика.
        Для Каждого ТекСтрокаМатериалыЗаказчика Из ОбъектОснование.МатериалыЗаказчика Цикл
            НоваяСтрока = МатериалыЗаказчика.Добавить();
            НоваяСтрока.Количество = ТекСтрокаМатериалыЗаказчика.Количество;
            НоваяСтрока.Номенклатура = ТекСтрокаМатериалыЗаказчика.Номенклатура;
            НоваяСтрока.СостояниеМатериала = ТекСтрокаМатериалыЗаказчика.СостояниеМатериала;
        КонецЦикла;
        
        // Перенос услуг.
        Для Каждого ТекСтрокаУслуги Из ОбъектОснование.Услуги Цикл
            НоваяСтрока = Услуги.Добавить();
            НоваяСтрока.Количество = ТекСтрокаУслуги.Количество;
            НоваяСтрока.Сумма = ТекСтрокаУслуги.Сумма;
            НоваяСтрока.Услуга = ТекСтрокаУслуги.Услуга;
            НоваяСтрока.Цена = ТекСтрокаУслуги.Цена;
        КонецЦикла;
    КонецЕсли;
    //}}__КОНСТРУКТОР_ВВОД_НА_ОСНОВАНИИ
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
    // 1. Подготовка – указываем, что движения будут записываться.
    Движения.ТоварыНаСкладах.Записывать = Истина;
    Движения.Продажи.Записывать = Истина;
    Движения.УчетЗатрат.Записывать = Истина;
    Движения.ЗаказыКлиентов.Записывать = Истина;
    Движения.МатериалыЗаказчиков.Записывать = Истина;
    Движения.Хозрасчетный.Записывать    = Истина;
    
    Движения.ТоварыНаСкладах.Записать();
    Движения.МатериалыЗаказчиков.Записать();
    
    // 2. Блокировка данных регистра остатков для обеспечения корректного списания.
    Блокировка = Новый БлокировкаДанных;
    ЭлементБлокировки = Блокировка.Добавить("РегистрНакопления.ТоварыНаСкладах");
    ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
    ЭлементБлокировки.ИсточникДанных = Товары;
    ЭлементБлокировки.ИспользоватьИзИсточникаДанных("Номенклатура", "Номенклатура");
    ЭлементБлокировки.УстановитьЗначение("Склад", Склад);
    Блокировка.Заблокировать();
    
    // 3. Основной запрос: объединяем товары и услуги в одну временную таблицу,
    //    получаем остатки с группировкой по партиям (срок годности) с сортировкой
    //    для реализации метода FEFO (списание сначала с истекающим сроком годности).
    Запрос = Новый Запрос;
    Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |    РеализацияТовары.Номенклатура КАК Номенклатура,
    |    СУММА(РеализацияТовары.Количество) КАК Количество,
    |    СУММА(РеализацияТовары.Сумма) КАК Сумма,
    |    &Склад КАК Склад
    |ПОМЕСТИТЬ ВТ_Товары
    |ИЗ
    |    Документ.Реализация.Товары КАК РеализацияТовары
    |ГДЕ
    |    РеализацияТовары.Ссылка = &Ссылка
    |
    |СГРУППИРОВАТЬ ПО
    |    РеализацияТовары.Номенклатура
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ
    |    РеализацияУслуги.Услуга,
    |    СУММА(РеализацияУслуги.Количество),
    |    СУММА(РеализацияУслуги.Сумма),
    |    NULL
    |ИЗ
    |    Документ.Реализация.Услуги КАК РеализацияУслуги
    |ГДЕ
    |    РеализацияУслуги.Ссылка = &Ссылка
    |
    |СГРУППИРОВАТЬ ПО
    |    РеализацияУслуги.Услуга
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |    ВТ_Товары.Номенклатура КАК Номенклатура,
    |    ВТ_Товары.Количество КАК КоличествоВДокументе,
    |    ВТ_Товары.Сумма КАК СуммаВДокументе,
    |    ТоварыНаСкладахОстатки.СрокГодности КАК СрокГодности,
    |    ЕСТЬNULL(ТоварыНаСкладахОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток,
    |    ЕСТЬNULL(ТоварыНаСкладахОстатки.СуммаОстаток, 0) КАК СуммаОстаток,
    |    ВТ_Товары.Номенклатура.СтатьяЗатрат КАК СтатьяЗатрат,
    |    ВТ_Товары.Номенклатура.Представление КАК НоменклатураПредставление,
    |    ВЫБОР
    |        КОГДА ВТ_Товары.Номенклатура.ТипНоменклатуры = ЗНАЧЕНИЕ(Перечисление.ТипыНоменклатуры.Услуга)
    |            ТОГДА ЛОЖЬ
    |        ИНАЧЕ ИСТИНА
    |    КОНЕЦ КАК ЭтоТовар,
    |    ВТ_Товары.Номенклатура.СчетБухгалтерскогоУчета КАК СчетБухгалтерскогоУчета
    |ИЗ
    |    ВТ_Товары КАК ВТ_Товары
    |        ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(
    |                &МоментВремени,
    |                (Номенклатура, Склад) В
    |                    (ВЫБРАТЬ
    |                        ВТ_Товары.Номенклатура,
    |                        ВТ_Товары.Склад
    |                    ИЗ
    |                        ВТ_Товары КАК ВТ_Товары)) КАК ТоварыНаСкладахОстатки
    |        ПО ВТ_Товары.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
    |            И ВТ_Товары.Склад = ТоварыНаСкладахОстатки.Склад
    |
    |УПОРЯДОЧИТЬ ПО
    |    СрокГодности
    |ИТОГИ
    |    МАКСИМУМ(КоличествоВДокументе),
    |    МАКСИМУМ(СуммаВДокументе),
    |    СУММА(КоличествоОстаток),
    |    СУММА(СуммаОстаток)
    |ПО
    |    СтатьяЗатрат,
    |    Номенклатура";
    
    Запрос.УстановитьПараметр("МоментВремени", Новый Граница(МоментВремени()));
    Запрос.УстановитьПараметр("Ссылка", Ссылка);
    Запрос.УстановитьПараметр("Склад", Склад);
    РезультатЗапроса = Запрос.Выполнить();
    
    // Обход результата с иерархией по СтатьяЗатрат -> Номенклатура -> детальные записи (партии).
    ВыборкаСтатьяЗатрат = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
    
    Пока ВыборкаСтатьяЗатрат.Следующий() Цикл
        СуммаЗатрат = 0;  // Общая себестоимость списания для данной статьи затрат.
        ВыборкаНоменклатура = ВыборкаСтатьяЗатрат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
        Пока ВыборкаНоменклатура.Следующий() Цикл
            
            Если ВыборкаНоменклатура.ЭтоТовар Тогда
                // Проверка достаточности общего остатка на складе.
                Если ВыборкаНоменклатура.КоличествоВДокументе > ВыборкаНоменклатура.КоличествоОстаток Тогда
                    Сообщение = Новый СообщениеПользователю;
                    Сообщение.Текст = СтрШаблон("Проведение запрещено. Отсутствуют остатки по номенклатуре ""%1"" в количестве ""%2""",
                        ВыборкаНоменклатура.НоменклатураПредставление,
                        ВыборкаНоменклатура.КоличествоВДокументе - ВыборкаНоменклатура.КоличествоОстаток);
                    Сообщение.Сообщить();
                    Отказ = Истина;
                    Продолжить;
                КонецЕсли;
                
                // Списание по партиям (FEFO: сначала с истекающим сроком годности).
                ОсталосьСписать = ВыборкаНоменклатура.КоличествоВДокументе;
                ВыборкаДетальныеЗаписи = ВыборкаНоменклатура.Выбрать();
                Пока ВыборкаДетальныеЗаписи.Следующий() И ОсталосьСписать > 0 Цикл
                    Если ВыборкаДетальныеЗаписи.КоличествоОстаток <= 0 Тогда
                        Продолжить;
                    КонецЕсли;
                    
                    Списываем = Мин(ВыборкаДетальныеЗаписи.КоличествоОстаток, ОсталосьСписать);
                    
                    Движение                 = Движения.ТоварыНаСкладах.ДобавитьРасход();
                    Движение.Период          = Дата;
                    Движение.Номенклатура    = ВыборкаДетальныеЗаписи.Номенклатура;
                    Движение.Склад           = Склад;
                    Движение.СрокГодности    = ВыборкаДетальныеЗаписи.СрокГодности;
                    Движение.Количество      = Списываем;
                    
                    // Расчёт суммы списания пропорционально остатку партии.
                    Если Списываем    = ВыборкаДетальныеЗаписи.КоличествоОстаток Тогда
                        СуммаСписания = ВыборкаДетальныеЗаписи.СуммаОстаток;
                    Иначе
                        СуммаСписания = Списываем / ВыборкаДетальныеЗаписи.КоличествоОстаток * ВыборкаДетальныеЗаписи.СуммаОстаток;
                    КонецЕсли;
                    Движение.Сумма    = СуммаСписания;
                    
                    ОсталосьСписать   = ОсталосьСписать - Списываем;
                    СуммаЗатрат       = СуммаЗатрат + СуммаСписания;
                    
                    // Проводка по списанию себестоимости: Дт 90 "Продажи" Кт счёт учёта номенклатуры.
                    Движение = Движения.Хозрасчетный.Добавить();
                    Движение.СчетДт      = ПланыСчетов.Хозрасчетный.Продажи;
                    Движение.СчетКт      = ВыборкаНоменклатура.СчетБухгалтерскогоУчета;
                    Движение.СубконтоКт[ПланыВидовХарактеристик.ВидыСубконтоХозрасчетные.Номенклатура] = ВыборкаДетальныеЗаписи.Номенклатура; 
                    Движение.Период      = Дата;    
                    Движение.Сумма       = СуммаСписания;
                    Движение.Содержание  = "Списана себестоимость товарно-материальных ценностей";
                    
                КонецЦикла;
            КонецЕсли;
            
            // Движение по регистру "Продажи" (выручка) – для товаров и услуг.
            ДвижениеПродажи                = Движения.Продажи.Добавить();
            ДвижениеПродажи.Период         = Дата;
            ДвижениеПродажи.Номенклатура   = ВыборкаНоменклатура.Номенклатура;
            ДвижениеПродажи.Контрагент     = Контрагент;
            ДвижениеПродажи.Сотрудник      = Сотрудник;
            ДвижениеПродажи.Количество     = ВыборкаНоменклатура.КоличествоВДокументе;
            ДвижениеПродажи.Сумма          = ВыборкаНоменклатура.СуммаВДокументе;
        КонецЦикла;
        
        // Движение по регистру "Учет затрат" – итоговая себестоимость по статье затрат.
        Если СуммаЗатрат > 0 Тогда
            ДвижениеЗатрат                = Движения.УчетЗатрат.Добавить();
            ДвижениеЗатрат.Период         = Дата;
            ДвижениеЗатрат.СтатьяЗатрат   = ВыборкаСтатьяЗатрат.СтатьяЗатрат;
            ДвижениеЗатрат.Сумма          = СуммаЗатрат;
        КонецЕсли;
    КонецЦикла;
    
    // 5. Движения по регистру "ЗаказыКлиентов" (расход суммы заказа),
    //    если документ создан на основании заказ-наряда.
    Если ЗначениеЗаполнено(ДокументОснование) Тогда
        ДвижениеЗаказа                = Движения.ЗаказыКлиентов.Добавить();
        ДвижениеЗаказа.ВидДвижения    = ВидДвиженияНакопления.Расход;
        ДвижениеЗаказа.Период         = Дата;
        ДвижениеЗаказа.Клиент         = Контрагент;
        ДвижениеЗаказа.ЗаказКлиента   = ДокументОснование;
        ДвижениеЗаказа.Сумма          = Услуги.Итог("Сумма");
    КонецЕсли;
    
    // 6. Движения по регистру "МатериалыЗаказчиков" (расход материалов клиента).
    Для каждого СтрокаМЗ Из МатериалыЗаказчика Цикл
        ДвижениеМЗ                = Движения.МатериалыЗаказчиков.ДобавитьРасход();
        ДвижениеМЗ.Период         = Дата;
        ДвижениеМЗ.Номенклатура   = СтрокаМЗ.Номенклатура;
        ДвижениеМЗ.Заказчик       = Контрагент;
        ДвижениеМЗ.Склад          = Склад;
        ДвижениеМЗ.Количество     = СтрокаМЗ.Количество;
    КонецЦикла;  
    
    // 7. Проводка по отражению выручки: Дт 62 "Расчеты с покупателями" Кт 90 "Продажи".
    Движение            = Движения.Хозрасчетный.Добавить();
    Движение.СчетДт     = ПланыСчетов.Хозрасчетный.РасчетыСПокупателями;
    Движение.СчетКт     = ПланыСчетов.Хозрасчетный.Продажи;
    БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(Движение.СчетДт, Движение.СубконтоДт, Контрагент);
    Движение.Период     = Дата;
    Движение.Сумма      = СуммаДокумента;
    Движение.Содержание = "Отражена выручка от реализации товаров и услуг";
    
КонецПроцедуры

#КонецОбласти