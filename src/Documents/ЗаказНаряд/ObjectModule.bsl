// Модуль объекта документа "ЗаказНаряд".
// Содержит логику проведения документа и предварительные расчёты перед записью.

// Основной обработчик проведения документа.
// Формирует движения по регистрам:
//   - "ЗаказыКлиентов" (общий приход суммой документа в разрезе клиента),
//   - "МатериалыЗаказчиков" (приход материалов клиента на склад).
#Область ОбработчикиСобытий
Процедура ОбработкаПроведения(Отказ, Режим)
    
    // 1. Указываем, что движения в этих регистрах будут записываться.
    Движения.ЗаказыКлиентов.Записывать = Истина;
    Движения.МатериалыЗаказчиков.Записывать = Истина;
    
    // 2. Движение по регистру "Заказы клиентов" (приход)     
    ДвижениеЗаказ = Движения.ЗаказыКлиентов.Добавить();
    ДвижениеЗаказ.ВидДвижения = ВидДвиженияНакопления.Приход;
    ДвижениеЗаказ.Период = Дата;
    ДвижениеЗаказ.Клиент = Клиент;
    ДвижениеЗаказ.ЗаказКлиента = Ссылка;   // ссылка на сам документ
    ДвижениеЗаказ.Сумма = СуммаДокумента;  // итоговая сумма документа
    
    // 3. Движения по регистру "Материалы заказчиков" (приход)
    // Для каждой строки табличной части "МатериалыЗаказчика" создаём приходное движение
    // на указанный склад с указанием заказчика (клиента).
    Для каждого СтрокаМЗ Из МатериалыЗаказчика Цикл
        ДвижениеМЗ = Движения.МатериалыЗаказчиков.Добавить();
        ДвижениеМЗ.ВидДвижения = ВидДвиженияНакопления.Приход;
        ДвижениеМЗ.Период = Дата;
        ДвижениеМЗ.Номенклатура = СтрокаМЗ.Номенклатура;
        ДвижениеМЗ.Заказчик = Клиент;       // владелец материалов – клиент
        ДвижениеМЗ.Склад = Склад;           // склад, на котором хранятся материалы клиента
        ДвижениеМЗ.Количество = СтрокаМЗ.Количество;
    КонецЦикла;
    
КонецПроцедуры

// Обработчик события "ПередЗаписью".
// Выполняет пересчёт итоговой суммы документа по табличной части "Услуги".
// Это позволяет всегда иметь актуальную сумму перед сохранением (и проведением).
Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
      Если ОбменДанными.Загрузка Тогда
        Возврат;
    КонецЕсли;
    
    СуммаДокумента = Услуги.Итог("Сумма");
КонецПроцедуры
#КонецОбласти