// Модуль объекта документа "БольничныйЛист".
// Содержит логику проведения больничного листа:
//   1. Расчёт пособия на основании оклада сотрудника (взятого из кадровой истории).
//   2. Формирование движений по регистру расчёта "Начисления" с разбивкой по месяцам
//      для корректного вытеснения других видов расчёта в разных периодах.
//   3. Принудительный расчёт сумм в регистре расчёта и последующее формирование
//      бухгалтерских проводок и записей в регистр "УчетЗатрат".
#Область ОбработчикиСобытий
Процедура ОбработкаПроведения(Отказ, Режим)
    Движения.Начисления.Записывать    = Истина;
    Движения.УчетЗатрат.Записывать    = Истина;
    Движения.Хозрасчетный.Записывать  = Истина;
    
    // Получение текущего оклада сотрудника на дату окончания больничного
    // из регистра сведений "КадроваяИсторияСотрудников".
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    КадроваяИсторияСотрудниковСрезПоследних.Оклад КАК Оклад
    |ИЗ
    |    РегистрСведений.КадроваяИсторияСотрудников.СрезПоследних(&Период, Сотрудник = &Сотрудник) КАК КадроваяИсторияСотрудниковСрезПоследних";
    Запрос.УстановитьПараметр("Период", ДатаОкончания);
    Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
    
    Результат = Запрос.Выполнить();
    
    Если Результат.Пустой() Тогда
        ПараметрРасчета = 0;
    Иначе
        ПараметрРасчета = Запрос.Выполнить().Выгрузить()[0].Оклад;
    КонецЕсли;
    
    // Определяем начальные и конечные месяцы, чтобы разбить больничный
    // по расчётным периодам. Это необходимо, чтобы в регистре расчёта
    // записи о больничном корректно вытесняли другие начисления в каждом месяце.
    МесяцНачисления = НачалоМесяца(ДатаНачала);
    МесяцОкончания = НачалоМесяца(ДатаОкончания);
    
    Пока МесяцНачисления <= МесяцОкончания Цикл
        Движение = Движения.Начисления.Добавить();
        Движение.Сторно = Ложь;
        Движение.ВидРасчета             = ПланыВидовРасчета.Начисления.Больничный;
        // Период действия – пересечение периода больничного и текущего месяца.
        Движение.ПериодДействияНачало   = Макс(ДатаНачала, МесяцНачисления);
        Движение.ПериодДействияКонец    = Мин(ДатаОкончания, КонецМесяца(МесяцНачисления));
        Движение.ПериодРегистрации      = ПериодНачисления;
        Движение.БазовыйПериодНачало    = Макс(ДатаНачала, МесяцНачисления);
        Движение.БазовыйПериодКонец     = Мин(ДатаОкончания, КонецМесяца(МесяцНачисления));
        Движение.Сотрудник              = Сотрудник;
        Движение.ПоказательРасчета      = ПараметрРасчета;
        
        МесяцНачисления = ДобавитьМесяц(МесяцНачисления, 1);
    КонецЦикла;
    
    Движения.Начисления.Записать();
    Движения.Начисления.РассчитатьСуммуНачисления();
    
    // Запрос к уже записанным движениям для получения сумм и статей затрат.
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |    Начисления.Сотрудник КАК Сотрудник,
    |    СУММА(Начисления.Сумма) КАК Сумма,
    |    Начисления.ВидРасчета.СтатьяЗатрат КАК СтатьяЗатрат
    |ИЗ
    |    РегистрРасчета.Начисления КАК Начисления
    |ГДЕ
    |    Начисления.Регистратор = &Регистратор
    |
    |СГРУППИРОВАТЬ ПО
    |    Начисления.Сотрудник,
    |    Начисления.ВидРасчета.СтатьяЗатрат";
    
    Запрос.УстановитьПараметр("Регистратор", Ссылка);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Выборка.Следующий();
    
    // Движение в регистр "Учет затрат" (общая сумма по статье).
    ДвижениеЗатрат = Движения.УчетЗатрат.Добавить();
    ДвижениеЗатрат.Период        = Дата;
    ДвижениеЗатрат.Сумма         = Выборка.Сумма;
    ДвижениеЗатрат.СтатьяЗатрат  = Выборка.СтатьяЗатрат;    
    // Бухгалтерская проводка: Дт 44 Кт 70.
    ДвижениеХозрасчетный = Движения.Хозрасчетный.Добавить();
    ДвижениеХозрасчетный.СчетДт        = ПланыСчетов.Хозрасчетный.РасходыНаПродажу;     
    ДвижениеХозрасчетный.СчетКт        = ПланыСчетов.Хозрасчетный.РасчетыСПерсоналомПоОплатеТруда;
    ДвижениеХозрасчетный.Период        = Дата;        
    ДвижениеХозрасчетный.Сумма         = Выборка.Сумма;        
    ДвижениеХозрасчетный.Содержание    = "Отражено начисление по больничному листу";
    БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(ДвижениеХозрасчетный.СчетДт, 
                    ДвижениеХозрасчетный.СубконтоДт, Выборка.СтатьяЗатрат);
    БухгалтерскийУчет.ЗаполнитьСубконтоПоСчету(ДвижениеХозрасчетный.СчетКт, 
                        ДвижениеХозрасчетный.СубконтоКт, Выборка.Сотрудник);    
КонецПроцедуры
#КонецОбласти