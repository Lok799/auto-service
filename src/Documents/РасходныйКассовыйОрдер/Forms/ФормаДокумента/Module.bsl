// Форма документа "РасходныйКассовыйОрдер".
// Обеспечивает:
//   - установку ответственного по умолчанию (текущий пользователь),
//   - динамическое управление типом получателя (контрагент или сотрудник) в зависимости от вида операции,
//   - управление видимостью поля "Договор" (скрыто для зарплатных и подотчетных выплат, а также для покупателей),
//   - проверку, является ли контрагент покупателем, для скрытия договора.

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
    // Заполнение ответственного текущим пользователем
    Если Не ЗначениеЗаполнено(Объект.Ответственный) Тогда
        Объект.Ответственный = ПараметрыСеанса.ТекущийПользователь;
    КонецЕсли;
    УправлятьВидимостьюЭлементовНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
    УправлятьТипомПолучателяНаКлиенте();
    УправлятьВидимостьюЭлементовНаСервере();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВидОперацииПриИзменении(Элемент)
    УправлятьТипомПолучателяНаКлиенте();
    УправлятьВидимостьюЭлементовНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПолучательПриИзменении(Элемент)
    УправлятьВидимостьюЭлементовНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Проверяет, является ли контрагент покупателем.
// Параметры:
//   СсылкаНаКонтрагента - СправочникСсылка.Контрагенты - (может быть пустой ссылкой).
// Возвращаемое значение:
//   Булево - Истина, если тип контрагента = Покупатель; Ложь в противном случае или если ссылка не заполнена.
&НаСервере
Функция КонтрагентПокупатель(СсылкаНаКонтрагента)   // убран Экспорт
    Если Не ЗначениеЗаполнено(СсылкаНаКонтрагента) Тогда
        Возврат Ложь;
    КонецЕсли;
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ
    |    Контрагенты.ТипКонтрагента = &ТипПокупатель КАК Покупатель
    |ИЗ
    |    Справочник.Контрагенты КАК Контрагенты
    |ГДЕ
    |    Контрагенты.Ссылка = &Ссылка";
    
    Запрос.УстановитьПараметр("Ссылка", СсылкаНаКонтрагента);
    Запрос.УстановитьПараметр("ТипПокупатель", Перечисления.ТипыКонтрагентов.Покупатель);
    
    Результат = Запрос.Выполнить();
    Выборка = Результат.Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Покупатель;
    КонецЕсли;
    
    Возврат Ложь;
КонецФункции

&НаСервере
Процедура УправлятьВидимостьюЭлементовНаСервере()
    Если Объект.ВидОперации = Перечисления.ВидыОперацийРасходаДенег.ВыдачаПодотчетнику
        Или Объект.ВидОперации = Перечисления.ВидыОперацийРасходаДенег.ВыдачаЗаработнойПлаты Тогда
        Элементы.Договор.Видимость = Ложь;
    Иначе
        Если ЗначениеЗаполнено(Объект.Получатель) И 
            ТипЗнч(Объект.Получатель) = Тип("СправочникСсылка.Контрагенты") Тогда
            ЯвляетсяПокупателем = КонтрагентПокупатель(Объект.Получатель);
            Элементы.Договор.Видимость = Не ЯвляетсяПокупателем;
        Иначе
            Элементы.Договор.Видимость = Истина;
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УправлятьТипомПолучателяНаКлиенте()
    Если Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходаДенег.ВыдачаПодотчетнику")
        Или Объект.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийРасходаДенег.ВыдачаЗаработнойПлаты") Тогда
        Элементы.Получатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Сотрудники");
        Если Объект.Получатель <> Неопределено И
            ТипЗнч(Объект.Получатель) <> Тип("СправочникСсылка.Сотрудники") Тогда
            Объект.Получатель = Неопределено;
        КонецЕсли;
    Иначе
        Элементы.Получатель.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.Контрагенты");
        Если Объект.Получатель <> Неопределено И
            ТипЗнч(Объект.Получатель) <> Тип("СправочникСсылка.Контрагенты") Тогда
            Объект.Получатель = Неопределено;
        КонецЕсли;
    КонецЕсли;
КонецПроцедуры

#КонецОбласти