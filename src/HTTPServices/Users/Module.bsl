// HTTP-сервис "getUser"
// Предоставляет данные о зарегистрированном пользователе по его логину.

// Обработчик GET-запроса на получение информации о пользователе.
// Параметры строки запроса:
//   username – строка, логин (наименование) пользователя
// Возвращает HTTP-ответ:
//   200 – успех, в теле JSON-массив с данными найденного пользователя
//         (пустой массив, если пользователь не найден)
//   400 – не передан обязательный параметр username
//   500 – внутренняя ошибка сервера
//
Функция getUserGET(Запрос)
    // Извлекаем логин из параметров запроса.
    Логин = Строка(Запрос.ПараметрыЗапроса.Получить("username"));
    
    // Если логин пустой, сразу возвращаем ошибку 400 (Bad Request).
    Если ПустаяСтрока(Логин) Тогда
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("Параметр username обязателен");
        Возврат Ответ;
    КонецЕсли;
    
    // Начинаем блок с обработкой исключений для страховки от нештатных ситуаций.
    Попытка
        // Формируем запрос к справочнику "Пользователи" по наименованию.
        ЗапросПользователи = Новый Запрос;
        ЗапросПользователи.Текст = "ВЫБРАТЬ
        |    УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Пользователи.Ссылка) КАК Ссылка,
        |    Пользователи.Наименование КАК Наименование,
        |    Пользователи.Код КАК Код
        |ИЗ
        |    Справочник.Пользователи КАК Пользователи
        |ГДЕ
        |    НЕ Пользователи.ПометкаУдаления
        |    И Пользователи.Наименование = &Наименование
        |
        |УПОРЯДОЧИТЬ ПО
        |    Наименование";
        
        ЗапросПользователи.УстановитьПараметр("Наименование", Логин);
        
        РезультатЗапроса = ЗапросПользователи.Выполнить();
        
        // Собираем данные в массив для последующей сериализации в JSON.
        МассивПользователей = Новый Массив;
        
        Выборка = РезультатЗапроса.Выбрать();
        Пока Выборка.Следующий() Цикл
            ДанныеПользователя = Новый Структура;
            ДанныеПользователя.Вставить("guid", Строка(Выборка.Ссылка));
            ДанныеПользователя.Вставить("name", Строка(Выборка.Наименование));
            ДанныеПользователя.Вставить("code", Строка(Выборка.Код));
            
            МассивПользователей.Добавить(ДанныеПользователя);
        КонецЦикла;
        
        // Формируем успешный ответ (200) с JSON-массивом.
        Ответ = Новый HTTPСервисОтвет(200);
        
        ЗаписьJSON = Новый ЗаписьJSON;
        ЗаписьJSON.УстановитьСтроку();
        ЗаписатьJSON(ЗаписьJSON, МассивПользователей);
        СтрокаОтвета = ЗаписьJSON.Закрыть();
        
        Ответ.УстановитьТелоИзСтроки(СтрокаОтвета);
        
        Возврат Ответ;
        
    Исключение
        // При любой ошибке возвращаем 500 с описанием.
        Ответ = Новый HTTPСервисОтвет(500);
        Ответ.УстановитьТелоИзСтроки("Ошибка при получении пользователя: " + ОписаниеОшибки());
        Возврат Ответ;
    КонецПопытки;
КонецФункции